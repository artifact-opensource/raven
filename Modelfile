FROM ./weights/raven-v1-ollama.gguf

# Raven v1.1 — base transformer (not instruction-tuned).
# Exported under the llama architecture for Ollama/llama.cpp compatibility.
# NOTE: pup_gate is dropped in this export (llama.cpp has no slot for it).
# Prefill works; autoregressive decode hangs on the base model until fine-tuned.

PARAMETER num_ctx 2048
PARAMETER temperature 0.7
PARAMETER stop "<s>"
PARAMETER stop "</s>"

TEMPLATE """{{ if .System }}{{ .System }}{{ end }}{{ if .Prompt }}<s>{{ .Prompt }}</s>{{ end }}{{ .Response }}"""

# Base model — no system persona. Left blank intentionally.
SYSTEM """"
